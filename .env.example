# Maestro'D — copy to .env for docker compose
# Enige externe dependency in compose: host LLM (LM Studio / oMLX)

# ── Local Builder (oMLX) — NIET voor docker compose
# API key hardcoded in scripts/local_builder.py: Mikey
# Zie docs/builder-session.md

# ── Product LLM (threat pipeline — tm-agent container)
# Voorlopig default: zelfde oMLX + Gemma 4 12B als Builder (:8002)
# Alternatief: LM Studio op :1234 met groter model (Qwen 27B)
MODEL_PROVIDER=ollama
LOCAL_MODEL=gemma-4-12B-it-8bit
INFERENCE_BASE_URL=http://host.docker.internal:8002/v1
INFERENCE_API_KEY=Mikey

# ── Database
POSTGRES_USER=maestro
POSTGRES_PASSWORD=maestro
POSTGRES_DB=maestro_d
DATABASE_URL=postgresql://maestro:maestro@postgres:5432/maestro_d

# ── Storage (no MinIO)
DIAGRAM_STORAGE_PATH=/data/diagrams

# ── App
LOCAL_USER=local-user
LOG_LEVEL=INFO

# ── Frontend (npm run dev)
VITE_APP_ENDPOINT=http://localhost:8000
VITE_SENTRY_ENABLED=false
# Dev with proxy: VITE_SENTRY_BASE_URL=/sentry
# Direct: VITE_SENTRY_BASE_URL=http://localhost:8090
